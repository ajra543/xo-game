# pyenv
#   For a library or app, you might want to share your .python-version.
#   Comment the next line if you do.
.python-version

# pipenv
#   According to pypa/pipenv#1102, Pipfile.lock should be kept in version control.
#   But or some projects, you may feel it's not needed, or want to ignore it.
#   Pipfile.lock

# poetry
#   Using Pipfile is preferred, but poetry also use pyproject.toml and poetry.lock.
#   poetry.lock

# pdm
#   Similar to Pipfile, PDM writes to __pypackages__ and pdm.lock
__pypackages__/

